# ----------------------------------------------------------------------------
# Copy this file to ".env" (in the project ROOT, not in /experiments) and fill
# in real values.
#   PowerShell:  Copy-Item experiments\.env.example .env
# NEVER commit the real ".env" — .gitignore already excludes it.
#
# Java analogy: this is your "application.properties.example" — a template that
# documents which secrets the app needs, without containing the secrets.
# ----------------------------------------------------------------------------

GROQ_API_KEY=your_groq_key_here

# Added in later milestones (M2 onward) — uncomment the ones you actually have:
# OPENAI_API_KEY=your_openai_key_here         # needs BILLING/credits or calls 429 'insufficient_quota'
# ANTHROPIC_API_KEY=your_anthropic_key_here   # direct Anthropic API (api.anthropic.com)
# NOVARELAY_API_KEY=your_novarelay_key_here   # OpenAI-compatible relay (novarelay.io) -> Claude/GPT/Gemini

# Ollama (local or remote) — OpenAI-compatible, NO API key. Setting the base URL
# is what enables this provider. OLLAMA_MODEL is optional (defaults in config.py).
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b
