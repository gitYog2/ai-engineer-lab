# ----------------------------------------------------------------------------
# Copy this file to ".env" (in the project ROOT, not in /experiments) and fill
# in real values.
#   PowerShell:  Copy-Item experiments\.env.example .env
# NEVER commit the real ".env" — .gitignore already excludes it.
#
# Java analogy: this is your "application.properties.example" — a template that
# documents which secrets the app needs, without containing the secrets.
# ----------------------------------------------------------------------------

GROQ_API_KEY=your_groq_key_here

# Added in later milestones (M2 onward) — leave commented until then:
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
